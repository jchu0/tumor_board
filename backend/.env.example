# Copy to .env and fill in. .env is gitignored.
ANTHROPIC_API_KEY=sk-ant-...

# Orchestrator model. Sonnet is the default for fast, cheap tool-use loops;
# swap to an Opus id if you want stronger reasoning and can spare the latency.
TUMOR_BOARD_MODEL=claude-sonnet-4-6

# CORS origin for the Vite dev server.
FRONTEND_ORIGIN=http://localhost:5173
